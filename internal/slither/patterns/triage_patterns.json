      "weight": 2,
      "max_matches": 5
    },
    {
      "id": "custom_security_or_compliance_surface",
      "pattern": "\\b(CSRF|JWT|password\\s+hash|session\\s+secret|encrypt|decrypt|HMAC|signature|sales\\s+tax|VAT|PCI)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "file_upload_boundary",
      "pattern": "\\b(multipart|chunked\\s+upload|resumable\\s+upload|upload\\s+stream|file\\s+upload)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "path_traversal_user_file_access",
      "pattern": "(?is)\\b(?:fs\\.(?:readFile|readFileSync|createReadStream)|os\\.(?:Open|ReadFile)|open|FileResponse|http\\.ServeFile|sendFile|download)\\s*\\([^;\\n]{0,240}\\b(?:req(?:uest)?\\.(?:query|params|body|url|form|args)|r\\.URL\\.Query\\(\\)\\.Get|request\\.(?:args|form|json|query_params|nextUrl\\.searchParams)|params\\s*\\[[\"'](?:path|file|filename)[\"']|searchParams\\.get\\s*\\(\\s*[\"'](?:path|file|filename)[\"'])",
      "weight": 5,
      "max_matches": 5
    },
    {
      "id": "path_join_request_input",
      "pattern": "(?is)\\b(?:path\\.(?:join|resolve)|filepath\\.(?:Join|Clean|Abs)|os\\.path\\.(?:join|abspath|normpath))\\s*\\([^;\\n]{0,240}\\b(?:req(?:uest)?\\.(?:query|params|body|url|form|args)|r\\.URL\\.Query\\(\\)\\.Get|request\\.(?:args|form|json|query_params|nextUrl\\.searchParams)|params\\s*\\[[\"'](?:path|file|filename)[\"']|searchParams\\.get\\s*\\(\\s*[\"'](?:path|file|filename)[\"'])",
      "weight": 5,
      "max_matches": 5
    },
    {
      "id": "upload_user_filename_write",
      "pattern": "(?is)\\b(?:fs\\.(?:writeFile|writeFileSync|createWriteStream)|os\\.(?:Create|OpenFile)|open|createWriteStream|saveAs|mv|move)\\s*\\([^;\\n]{0,260}\\b(?:file\\.originalname|req\\.file\\.originalname|req\\.files?\\[[^\\]]+\\]\\.name|uploadedFile\\.name|UploadFile\\.filename|\\.Filename\\b)",
      "weight": 5,
      "max_matches": 5
    },
    {
      "id": "archive_extract_surface",
      "pattern": "\\b(?:extractall\\s*\\(|tarfile\\.open\\s*\\(|zipfile\\.ZipFile\\s*\\(|new\\s+AdmZip\\s*\\(|extract[-]zip|unzipper\\.|archiver\\.|archive[/]zip|tar\\.x\\s*\\(|tar\\.extract\\s*\\()",
      "weight": 4,
      "max_matches": 5
    },
    {
      "id": "rate_limit_boundary",
      "pattern": "\\b(rate[-_ ]?limit|throttle|quota|token\\s+bucket|leaky\\s+bucket)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "pdf_or_email_delivery_boundary",
      "pattern": "\\b(PDF\\s+generation|pdf-lib|puppeteer|SMTP|DKIM|SPF|email\\s+delivery|send\\s+email)\\b",
      "weight": 2,
      "max_matches": 5
    },
    {
      "id": "vector_or_llm_infrastructure_boundary",
      "pattern": "\\b(vector\\s+DB|vector\\s+database|similarity\\s+search|LLM\\s+integration|tool\\s+calling|embedding\\s+provider)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "formal_proof_boundary",
      "pattern": "\\b(axiom|theorem|lemma|proof\\s+by\\s+contradiction|universal\\s+quantifier|existential\\s+quantifier|domain\\/codomain|formal\\s+system)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "invariant_or_symmetry_boundary",
      "pattern": "\\b(invariant|symmetry\\s+group|coordinate[-_ ]?independent|diffeomorphism|gauge\\s+invariance|topolog(?:y|ical)|metric\\s+space|Hilbert\\s+space)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "math_edge_or_limit_boundary",
      "pattern": "\\b(convergence\\s+proof|infinite\\s+series|boundary\\s+condition|degenerate\\s+case|dimensionality|fixed[-_ ]?point\\s+theorem|path\\s+integral)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "cache_without_invalidation_cue",
      "pattern": "\\b(cache|Cache|Redis|Memcached)\\b(?:(?!\\b(invalidate|ttl|expire|expiration|evict|delete|purge)\\b).){0,240}\\b(Set|Put|Store|Remember)\\s*\\(",
      "weight": 2,
      "max_matches": 4
    }
  ]
}
