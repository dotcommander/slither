      "pattern": "\\b(typed-nil|nil\\s+interface|err\\s+shadowed|loop-variable\\s+capture|deferred\\s+Close\\(\\)|value receiver.+sync\\.Mutex|early return before defer)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "js_ts_common_footgun",
      "pattern": "\\b(forEach\\s+with\\s+async|floating promises?|non-null assertion|Promise\\.all\\s+rejects on first failure|\\|\\|\\s+vs\\s+\\?\\?|as\\s+casts\\s+bypass)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "cross_language_security_footgun",
      "pattern": "\\b(TOCTOU|Time-of-Check-to-Time-of-Use|hostname validation|substring contains|evil-example\\.com|regex anchoring|unreleased resources)\\b",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "sdk_contextless_public_method",
      "pattern": "(?m)^func \\(c \\*Client\\) [A-Z]\\w+\\((?!ctx\\s+context\\.Context)",
      "weight": 3,
      "max_matches": 5
    },
    {
      "id": "custom_infra_reinvention",
      "pattern": "\\b(custom|homegrown|hand.?rolled|roll your own|TODO.*standardize|should standardize|utils|helpers)\\b",
      "weight": 2,
      "max_matches": 5
    },
    {
      "id": "resource_factory",
